<%- include("partials/header"); -%>

  <%- include("partials/admin-navbar"); -%>

  <div class="centered">

    <div class="form-card">

      <%- include("partials/images/student-img"); -%>

      <form action="/add-student" method="post">

        <div class="row">
          <%- include("partials/entry/name-entry"); -%>
        </div>

        <div class="row">
          <%- include("partials/entry/email-entry"); -%>
        </div>

        <div class="row">
          <%- include("partials/entry/branch-entry"); -%>
          <%- include("partials/entry/contact-entry"); -%>
        </div>

        <div class="row">
          <%- include("partials/entry/section-entry"); -%>
          <%- include("partials/entry/gender-entry"); -%>
        </div>

        <div class="row">
          <%- include("partials/entry/year-entry"); -%>
        </div>

        <div class="row">
          <%- include("partials/entry/password-entry"); -%>
          <%- include("partials/entry/confirm-password-entry"); -%>
        </div>

        <div class="row">
          <%- include("partials/entry/admin-password-entry"); -%>
        </div>

        <button type="submit" class="btn btn-outline-dark btn-md">Add</button>

        <%- include("partials/error"); -%>

      </form>

    </div>

<%- include("partials/footer"); -%>
